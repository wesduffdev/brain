# Engine environment — copy to `.env` and fill in real values. `.env` is
# gitignored and must never be committed (V0-SEC, ADR 0005). This template is
# safe to commit because it holds placeholders only.
#
#   cp .env.example .env      # then edit JWT_SECRET
#
# `docker compose up` reads these for the engine service; local dev reads them
# from your shell (e.g. `export $(grep -v '^#' .env | xargs)`), and
# `make token` mints a service token against the same JWT_SECRET.

# HS256 signing secret shared by the engine (verify) and `make token` (mint).
# Use a long random value in real deployments (>=32 bytes). CHANGE THIS.
JWT_SECRET=change-me

# Always-on API auth. Leave "true"; set "false" only for throwaway local dev
# (documented dev-only no-op — there is no localhost/loopback bypass).
AUTH_REQUIRED=true

# Token claims the engine verifies (iss/aud) and the default lifetime.
JWT_ISSUER=jarvis
JWT_AUDIENCE=jarvis-engine
JWT_TTL_SECONDS=3600

# Postgres connection for persistence (V0-7, ADR 0007). Read from the environment
# only — `docker compose` sets it for the engine service; local host dev exports
# it and `make migrate` uses it. These are throwaway local-dev creds, not a real
# secret. The dialect must be `postgresql+psycopg` (psycopg 3).
DATABASE_URL=postgresql+psycopg://sim:sim@localhost:5432/being_sim
