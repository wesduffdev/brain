# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
.pytest_cache/

# ML artifacts (weights are reproducible; keep them out of git)
models/*.pt
models/*.metrics.json

# Node / renderer
node_modules/
renderer/dist/

# OS / editor
.DS_Store
.idea/

# Claude Code — local settings and parallel-work worktrees
.claude/settings.local.json
.claude/worktrees/

# Secrets — never commit real secrets or keys (V0-SEC, ADR 0005).
# The committed template is .env.example; real values live in an untracked .env.
.env
*.pem
*.key
