# Renderer environment — copy to `.env` for local `npm run dev`. Vite exposes
# only `VITE_`-prefixed vars to the browser. `.env` is gitignored; commit only
# this template. There is NO login in v0 (ADR 0010): the token is a service JWT
# minted server-side.
#
#   cp .env.example .env
#   # from the repo root, with JWT_SECRET set in the root .env:
#   make token          # prints a JWT — paste it as VITE_ENGINE_TOKEN below
#
# then `npm run dev` and open http://localhost:5173.

# Where the browser reaches the engine (host:port of the engine's published
# port). The browser runs on your machine, so this is localhost even under
# docker-compose, not the compose-internal `engine` hostname.
VITE_ENGINE_HOST=localhost:8000

# The minted service token (see `make token`). Sent as the WS `?token=` query
# param and the `POST /command` bearer header. Required whenever the engine runs
# with AUTH_REQUIRED=true (the default). WARNING: this value is visible to the
# browser — it is a short-lived dev service token, never a real user credential.
VITE_ENGINE_TOKEN=

# Set to "true" to use wss/https (behind TLS). Defaults to ws/http for local dev.
VITE_ENGINE_SECURE=false
